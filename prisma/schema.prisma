// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  requester
  operator
  admin
}

enum Priority {
  Low
  Normal
  High
  Critical
}

enum RequestStatus {
  New
  InProgress
  OnPrinter
  Completed
  OnHold
  Canceled
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  role          UserRole @default(requester)
  createdAt     DateTime @default(now())

  // Relations
  requests      PrintRequest[]
  statusChanges StatusHistory[]
}

model PrintRequest {
  id            String        @id @default(cuid())
  requesterId   String
  requester     User          @relation(fields: [requesterId], references: [id])
  
  partNumber    String
  quantity      Int           @default(1)
  requiredDate  DateTime
  priority      Priority      @default(Normal)
  fileReference String?       // e.g. "PDM: EXH-12345.SLDPRT" or "\\server\path\file.stl"
  description   String?
  
  status        RequestStatus @default(New)
  operatorNotes String?       // Internal notes for operator
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  statusHistory StatusHistory[]
}

model StatusHistory {
  id          String        @id @default(cuid())
  requestId   String
  request     PrintRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  oldStatus   RequestStatus
  newStatus   RequestStatus
  changedById String
  changedBy   User          @relation(fields: [changedById], references: [id])
  comment     String?
  
  changedAt   DateTime      @default(now())
}
